%% Module Dependency Graph — Floor
%% Solid arrows = Python imports. Dashed arrows = subprocess invocations.
%% Dotted arrows = read/write by scripts or Claude.
%% Generated by architecture health check. Do not edit manually.

graph TD
    subgraph scripts["Scripts"]
        floor["floor.py\n[L0 — Entry]"]
        shutdown["shutdown.py\n[L1 — Orchestrator]"]
        check_manifest["check_manifest.py\n[L2 — Check]"]
        check_cdocs["check_cdocs.py\n[L2 — Check]"]
        check_coverage["check_cdoc_coverage.py\n[L2 — Check]"]
        task_counter["task_counter.py\n[L3 — Domain]"]
        hash_util["hash_util.py\n[L4 — Utility]"]
    end

    subgraph data["Shared State"]
        session[".floor_session.json"]
        counter_file["task_counter.txt"]
        hashes_file["cdoc_hashes.json"]
    end

    subgraph docs["Project Management Docs"]
        prompting["prompting.md"]
        status["status.md"]
        manifest["manifest.md"]
        cdoc_instr["cdoc.md"]
        implement["prompts/implement-this.md"]
        cdocs["cdocs/*.md"]
        standards["standards/*.md"]
    end

    %% Subprocess invocations
    floor -.->|subprocess| check_cdocs
    floor -.->|"subprocess (read)"| task_counter
    shutdown -.->|subprocess| check_manifest
    shutdown -.->|subprocess| check_cdocs
    shutdown -.->|subprocess| check_coverage
    shutdown -.->|"subprocess (increment)"| task_counter

    %% Python imports
    check_cdocs -->|import| hash_util
    check_coverage -->|import| hash_util

    %% Script reads
    floor -.->|read| prompting
    floor -.->|read| status
    check_manifest -.->|read| manifest
    check_cdocs -.->|read| cdocs
    check_coverage -.->|read| cdocs

    %% Script state writes
    floor -.->|write| session
    shutdown -.->|delete| session
    task_counter -.->|write| counter_file
    check_cdocs -.->|write| hashes_file

    %% Claude reads/writes (via CLAUDE.md directives)
    implement -.->|"Claude reads"| manifest
    implement -.->|"Claude reads"| cdocs
    implement -.->|"Claude reads"| standards
