%% State Mutation Flow — Floor
%% Shows which actors (scripts and Claude) write to each piece of shared state.
%% Generated by architecture health check. Do not edit manually.

flowchart LR
    subgraph actors_scripts["Scripts"]
        floor["floor.py"]
        shutdown["shutdown.py"]
        check_cdocs["check_cdocs.py"]
        task_counter["task_counter.py"]
    end

    subgraph actors_claude["Claude Agents"]
        ca["Claude\n(prompting session)"]
        ci["Claude Code\n(impl session)"]
    end

    subgraph state_data["Data Files"]
        session[".floor_session.json"]
        counter["task_counter.txt"]
        hashes["cdoc_hashes.json"]
    end

    subgraph state_docs["Project Management Docs"]
        implement["prompts/implement-this.md"]
        manifest["manifest.md"]
        status["status.md"]
        cdocs["cdocs/*.md"]
        prompting["prompting.md"]
    end

    %% Script mutations
    floor -->|"create"| session
    ca -->|"update status_item_id"| session
    shutdown -->|"delete"| session
    task_counter -->|"read / increment / reset"| counter
    check_cdocs -->|"update hashes"| hashes

    %% Claude mutations
    ca -->|"write final prompt"| implement
    ci -->|"add/remove rows"| manifest
    ci -->|"complete task"| status
    ci -->|"update stale docs"| cdocs
    ci -->|"add routing row (new cdoc)"| prompting
